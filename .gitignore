# Internal planning / migration artifacts (not for public repo)
legacy/
legdocs/

# Throwaway diagnostic plot scripts + their generated PNGs.
# `benchmarks/bench/` is real perf-measurement infrastructure and stays tracked.
benchmarks/plots/

# Synthetic realization files for the statistical bench — regenerable in
# ~5 s from `benchmarks/bench/gen_synth.py`, large enough that we don't
# bloat the repo with them.
benchmarks/bench/synth/

# Comparison plots generated by reference/validation/*/compare.py — regenerable
# from the committed CSVs, so we don't bloat the repo with PNGs.
reference/validation/*/plots/

# Proprietary / large clock recordings used for off-repo validation
reference/clock_data/

# Scratchpad files (Ian's REPL throwaways, never checked in)
scratch.jl
scratch.py
scratch/

# Internal planning docs (not for public repo)
docs/superpowers/

# One-off repo-setup script
makedir.sh

# Literate.jl-generated tutorial pages. `docs/make.jl` walks
# `examples/*.jl` and renders each into `docs/src/tutorials/<name>.md`
# at build time; the `.jl` files are the single source of truth.
# Hand-written tutorials (e.g. `single_clock_holdover.md`) are NOT
# matched by this pattern — only the numeric-prefix Literate output is.
docs/src/tutorials/0*_*.md
